{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "FastAPI REST API",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["api:app", "--reload", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "MCP HTTP Server",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["mcp_http_server:app", "--reload", "--port", "8001"],
      "port": 8001
    },
    {
      "name": "MCP stdio Server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["mcp_server.py"],
      "port": null
    }
  ]
}
